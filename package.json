{
  "name": "vibelens",
  "version": "0.1.1",
  "private": true,
  "description": "A visual co-pilot for vibe coding — preview, annotate, and tweak AI-generated UI in the browser",
  "author": "Shandar Junaid / Affordance Design Studios <hello@affordancedesign.in>",
  "license": "MIT",
  "homepage": "https://affordance.design",
  "repository": {
    "type": "git",
    "url": "https://github.com/shandar/VibeLens.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'packages/*/src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,css,json}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx,css,json}'",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
