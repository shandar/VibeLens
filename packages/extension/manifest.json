{
  "manifest_version": 3,
  "name": "VibeLens",
  "version": "0.1.0",
  "description": "Visual co-pilot for vibe coding — preview, annotate, and tweak AI-generated UI",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "VibeLens",
    "default_icon": {
      "16": "public/icon-16.png",
      "32": "public/icon-32.png",
      "48": "public/icon-48.png",
      "128": "public/icon-128.png"
    }
  },
  "icons": {
    "16": "public/icon-16.png",
    "32": "public/icon-32.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "csp_bypass",
        "enabled": true,
        "path": "public/csp-rules.json"
      }
    ]
  },
  "commands": {
    "toggle-annotations": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle annotation mode"
    },
    "toggle-diff": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Toggle visual diff overlay"
    }
  }
}
